# 敏感文件（包含 API keys、tokens）
local/
**/.zshrc.local
**/.zsh_history
**/.bash_history

# 缓存和临时文件
**/.zcompdump*
**/.netrwhist
**/*.backup
**/*.bak
**/*~
.DS_Store

# TPM 插件
tmux/.tmux/plugins/

